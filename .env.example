# MallPilot 环境变量配置示例
# 复制此文件为 .env 并填写实际配置。

APP_NAME=MallPilot
APP_ENV=production
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_MODEL=deepseek-chat

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=mallpilot123

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./data/chroma

PROMETHEUS_PORT=9091
ANOMALY_DETECTION_THRESHOLD=2.0

EVAL_BASELINE_PATH=./data/eval/baseline.json

MALLPILOT_MYSQL_HOST=127.0.0.1
MALLPILOT_MYSQL_PORT=3306
MALLPILOT_MYSQL_USER=mallpilot
MALLPILOT_MYSQL_PASSWORD=mallpilot123
MALLPILOT_MYSQL_DATABASE=mallpilot
MALLPILOT_MYSQL_CHARSET=utf8mb4
MALLPILOT_MYSQL_CONNECT_TIMEOUT=5
MALLPILOT_SEED_DEMO_DATA=true
MALLPILOT_SKILLS_DIR=./skills
MALLPILOT_SKILLS_MAX_PROMPT_CHARS=5000

SECRET_KEY=change_this_in_production
JWT_SECRET_KEY=change_this_in_production

ENABLE_SWAGGER_UI=true
ENABLE_MONITORING=true
ENABLE_EVALUATION=true
